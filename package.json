{
  "name": "claude-token-tracker",
  "displayName": "Monitor de Sesión Claude",
  "description": "Supervisa en tiempo real el consumo de tokens y el coste de tus sesiones con Claude Code, directamente desde tu barra de estado.",
  "version": "1.0.0",
  "publisher": "gatografiko",
  "repository": {
    "type": "git",
    "url": "https://github.com/gatografiko/claude-token-tracker.git"
  },
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeTokenTracker.reset",
        "title": "Claude Code - Tokens Session Tracker: Reset Session"
      },
      {
        "command": "claudeTokenTracker.showDetail",
        "title": "Claude Code - Tokens Session Tracker: Show Detail"
      }
    ],
    "configuration": {
      "title": "Claude Code - Tokens Session Tracker",
      "properties": {
        "claudeTokenTracker.model": {
          "type": "string",
          "default": "sonnet",
          "enum": ["sonnet", "opus", "haiku"],
          "description": "Modelo Claude para estimación de coste"
        },
        "claudeTokenTracker.currency": {
          "type": "string",
          "default": "USD",
          "enum": ["USD", "EUR"],
          "description": "Moneda para mostrar el coste"
        }
      }
    }
  }
}