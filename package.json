{
  "name": "claude-token-tracker",
  "displayName": "Claude Token Tracker",
  "description": "Monitor en tiempo real del uso de tokens de Claude Code en la barra de estado de VSCode",
  "version": "1.0.0",
  "publisher": "gatografiko",
  "repository": {
    "type": "git",
    "url": "https://github.com/gatografiko/claude-token-tracker.git"
  },
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeTokenTracker.reset",
        "title": "Claude Token Tracker: Reset Session"
      },
      {
        "command": "claudeTokenTracker.showDetail",
        "title": "Claude Token Tracker: Show Detail"
      }
    ],
    "configuration": {
      "title": "Claude Token Tracker",
      "properties": {
        "claudeTokenTracker.model": {
          "type": "string",
          "default": "sonnet",
          "enum": ["sonnet", "opus", "haiku"],
          "description": "Modelo Claude para estimación de coste"
        },
        "claudeTokenTracker.currency": {
          "type": "string",
          "default": "USD",
          "enum": ["USD", "EUR"],
          "description": "Moneda para mostrar el coste"
        }
      }
    }
  }
}